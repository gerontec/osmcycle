; renderd configuration for the CyclOSM tile server.
; Copy to /etc/renderd.conf and adjust paths for your machine.
; NOTE: plugins_dir must match your installed Mapnik version. On Ubuntu 26.04
; with Mapnik 4.2 the PostGIS reader ships as "postgis+pgraster.input" inside:
;   /usr/lib/x86_64-linux-gnu/mapnik/4.2/input

[renderd]
pid_file=/run/renderd/renderd.pid
stats_file=/run/renderd/renderd.stats
socketname=/run/renderd/renderd.sock
num_threads=8
tile_dir=/var/cache/renderd/tiles

[mapnik]
plugins_dir=/usr/lib/x86_64-linux-gnu/mapnik/4.2/input
font_dir=/usr/share/fonts/truetype
font_dir_recurse=true

[cyclosm]
URI=/tiles/cyclosm/
TILEDIR=/var/cache/renderd/tiles
XML=/home/gh/python/osmcycle/style/mapnik.xml
HOST=localhost
TILESIZE=256
MAXZOOM=20
